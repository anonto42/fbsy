#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass() { echo -e "${GREEN}[ok]${NC} $1"; }
fail() { echo -e "${RED}[fail]${NC} $1"; exit 1; }
info() { echo -e "${YELLOW}[fbsy pre-commit]${NC} $1"; }

info "Running pre-commit checks..."

# 1. Formatting
info "cargo fmt --check"
if ! cargo fmt --all -- --check 2>&1; then
  fail "Format check failed. Run: cargo fmt --all"
fi
pass "formatting"

# 2. Linting
info "cargo clippy"
if ! cargo clippy --all-targets --all-features -- -D warnings 2>&1; then
  fail "Clippy found warnings. Fix them or suppress with #[allow(...)]."
fi
pass "clippy"

# 3. Tests
info "cargo test"
if ! cargo test 2>&1; then
  fail "Tests failed. Fix failing tests before committing."
fi
pass "tests"

# 4. Auto-bump the patch version so every commit ships a new release.
#    Skip with: FBSY_NO_BUMP=1 git commit ...
if [ "${FBSY_NO_BUMP:-0}" = "1" ]; then
  info "version bump skipped (FBSY_NO_BUMP=1)"
else
  current="$(grep -m1 -E '^version = "[0-9]+\.[0-9]+\.[0-9]+"' Cargo.toml \
    | sed -E 's/version = "([0-9]+\.[0-9]+\.[0-9]+)"/\1/')"
  if [ -z "$current" ]; then
    fail "could not read version from Cargo.toml"
  fi
  major="${current%%.*}"
  rest="${current#*.}"
  minor="${rest%%.*}"
  patch="${rest#*.}"
  new="${major}.${minor}.$((patch + 1))"

  # Update the package version in Cargo.toml (first version line only).
  awk -v new="$new" '
    BEGIN { done = 0 }
    !done && /^version = "[0-9]+\.[0-9]+\.[0-9]+"/ {
      sub(/version = "[0-9]+\.[0-9]+\.[0-9]+"/, "version = \"" new "\"")
      done = 1
    }
    { print }
  ' Cargo.toml > Cargo.toml.bump && mv Cargo.toml.bump Cargo.toml

  # Keep Cargo.lock in sync (the version line under the fingerbridge package).
  if [ -f Cargo.lock ]; then
    awk -v new="$new" '
      /^name = "fingerbridge"$/ { found = 1 }
      found && /^version = "/ {
        sub(/version = ".*"/, "version = \"" new "\"")
        found = 0
      }
      { print }
    ' Cargo.lock > Cargo.lock.bump && mv Cargo.lock.bump Cargo.lock
  fi

  git add Cargo.toml Cargo.lock
  pass "version bumped ${current} -> ${new}"
fi

echo -e "${GREEN}All pre-commit checks passed.${NC}"
